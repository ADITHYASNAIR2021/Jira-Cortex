# ===========================================
# JIRA CORTEX - ENVIRONMENT CONFIGURATION
# ===========================================
# SECURITY: Never commit .env file to version control!
# Copy this to .env and fill in your values.

# ---------------------------------------------
# OpenAI Configuration
# ---------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# ---------------------------------------------
# Qdrant Vector Database
# ---------------------------------------------
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=jira_cortex_docs

# ---------------------------------------------
# Redis Cache
# ---------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_CACHE_TTL_SECONDS=10

# ---------------------------------------------
# Atlassian Configuration
# ---------------------------------------------
ATLASSIAN_CLIENT_ID=your-atlassian-client-id
ATLASSIAN_CLIENT_SECRET=your-atlassian-client-secret
ATLASSIAN_BASE_URL=https://api.atlassian.com

# ---------------------------------------------
# Security Settings
# ---------------------------------------------
# JWT secret for internal tokens (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=generate-a-secure-256-bit-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS=https://*.atlassian.net,https://*.jira.com

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ---------------------------------------------
# Application Settings
# ---------------------------------------------
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO

# Ingestion settings
INGESTION_BATCH_SIZE=50
CHUNK_SIZE_TOKENS=500
MAX_CHUNKS_PER_QUERY=3

# ---------------------------------------------
# Billing/Usage Tracking
# ---------------------------------------------
ENABLE_USAGE_TRACKING=true
DATABASE_URL=postgresql://user:password@localhost:5432/cortex_billing

# ---------------------------------------------
# Tenant Gating (Commercial)
# ---------------------------------------------
# Comma-separated list of allowed tenant cloud IDs
# Empty in development = allow all tenants
# In production, list your paying customers' cloud IDs
ALLOWED_TENANTS=

# ---------------------------------------------
# Stripe Payments (Financial Fortress)
# ---------------------------------------------
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Create a Product + Price in Stripe for the $299/mo subscription
STRIPE_PLATFORM_PRICE_ID=price_your_subscription_price_id

# Frontend URL for Stripe redirect after payment
APP_FRONTEND_URL=https://your-jira-instance.atlassian.net
